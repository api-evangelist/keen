  "info": {
    "_postman_id": "054cffad-7368-46ae-bd7f-5904e609988b",
    "name": "Keen Data Extraction API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Keen Data Extraction API enables developers to retrieve raw event data from event collections. It supports filtering, time framing, and selection of specific properties, and is useful for exporting data for external analysis, auditing, or feeding data into other systems and processing pipelines. Synchronous extractions return JSON responses; asynchronous extractions deliver result files via email.\n\nContact Support:\n Name: Keen Support",
      "type": "text/plain"
    }
  }
