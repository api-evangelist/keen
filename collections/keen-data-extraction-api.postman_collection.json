      "name": "Extractions",
      "description": {
        "content": "Extract raw event data from Keen event collections.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "a5875d28-5e72-4b45-82c4-f94561d65137",
          "name": "Keen Extract events synchronously",
          "request": {
            "name": "Keen Extract events synchronously",
            "description": {
              "content": "Returns up to 100,000 raw events from the specified event collection that match the supplied filters and time frame. For larger result sets, use the asynchronous extraction by supplying an email_address.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "projects",
                ":projectId",
                "queries",
                "extraction"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "event_collection",
                  "value": "<string>",
                  "description": "(Required) Event collection to extract from."
                },
                {
                  "disabled": false,
                  "key": "timeframe",
                  "value": "<string>",
                  "description": "(Required) Relative or absolute time frame for the extraction."
                },
                {
                  "disabled": false,
                  "key": "filters",
                  "value": "<string>",
                  "description": "JSON-encoded array of filter objects."
                },
                {
                  "disabled": false,
                  "key": "latest",
                  "value": "<integer>",
                  "description": "Limit the response to the latest N events."
                },
                {
                  "disabled": false,
                  "key": "email_address",
                  "value": "<email>",
                  "description": "When provided, runs extraction asynchronously and emails a result link."
                },
                {
                  "disabled": false,
                  "key": "property_names",
                  "value": "<string>",
                  "description": "Comma-separated list of property names to include."
                },
                {
                  "disabled": false,
                  "key": "timezone",
                  "value": "<string>",
                  "description": "Time zone offset for relative timeframes."
                }
              ],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "projectId",
                  "description": "(Required) Keen project identifier."
                }
              ]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
